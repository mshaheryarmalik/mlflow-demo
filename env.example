# ─────────────────────────────────────────────────────────────────
# MLflow Demo — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_HOST_PORT=5450

# ── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MLFLOW_BUCKET_NAME=mlflow-artifacts
MINIO_S3_PORT=9002
MINIO_CONSOLE_PORT=9091

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── AWS / MinIO credentials
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://localhost:9002

# ── Ollama ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Swap to any model available on ollama.com (e.g. mistral, gemma3, phi4)
OLLAMA_MODEL=llama3.2:1b
